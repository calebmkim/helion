index 06b59c20..02843778 100644
--- a/examples/long_sum.py
+++ b/examples/long_sum.py
@@ -12,6 +12,8 @@ This example demonstrates how to implement efficient sum reduction along a long
 # %%
 from __future__ import annotations
 
+from typing import Callable
+
 import torch
 
 import helion
@@ -192,3 +194,25 @@ def main() -> None:
 
 if __name__ == "__main__":
     main()
+
+
+# %%
+# Benchmark Wrapper
+# -----------------
+def longsum_tritonbench(tb_op: object, x: torch.Tensor) -> Callable[[], torch.Tensor]:
+    """Wrapper for tritonbench. Mirrors ``sum_tritonbench``: the ``sum`` operator
+    feeds a 1D tensor by default, so reshape to 2D for the row-reduction kernel.
+
+    The module-level ``longsum`` ships a BAKED ``config=...`` which would shadow the
+    reduction-seed heuristic at effort=none. To benchmark the SEED, we run a
+    config-free clone of the same kernel body so ``default_config()`` resolves to the
+    seed (when ``HELION_PROMOTE_REDUCTION_SEED=1``) or the base default otherwise.
+    """
+    seeded = helion.kernel(longsum.fn, static_shapes=True)
+
+    def compute_long_sum() -> torch.Tensor:
+        if x.ndim == 1:
+            return seeded(x.unsqueeze(0)).squeeze()
+        return seeded(x)
+
+    return compute_long_sum
